{
  "seed": 123,
  "device": "auto",
  "agent": {
    "gamma": 0.99,
    "lr": 1e-4,
    "batch_size": 256,
    "buffer_size": 100000,
    "epsilon_start": 0.3,
    "epsilon_end": 0.05,
    "epsilon_decay_steps": 40000,
    "target_update_interval": 2000,
    "train_freq": 4,
    "learn_starts": 1000,
    "double_dqn": true,
    "hidden_sizes": [256, 256]
  },
  "curriculum": {
    "solo": {
      "enabled": false,
      "max_episodes": 0,
      "max_steps_per_episode": 600,
      "exit_win_rate": 1.1,
      "exit_window": 100,
      "my_colour": "red",
      "reward": {}
    },
    "vs_random": {
      "enabled": true,
      "max_episodes": 1500,
      "max_steps_per_episode": 600,
      "exit_win_rate": 0.80,
      "exit_window": 100,
      "my_colour": "red",
      "reward": {
        "per_pin_home": 1.0,
        "step_penalty": 0.001,
        "all_home_bonus": 20.0,
        "distance_shaping": 0.05,
        "win_bonus": 10.0,
        "lose_penalty": -5.0
      }
    }
  },
  "eval": {"episodes": 50, "max_steps_per_episode": 600},
  "output": {
    "checkpoint_dir": "rl/checkpoints",
    "metrics_dir": "rl/checkpoints/metrics",
    "checkpoint_name": "dqn_latest.pt",
    "best_name": "dqn_best.pt"
  }
}
